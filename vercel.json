{
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    },
    "api/cron/daily-digest.js": {
      "maxDuration": 120
    },
    "api/cron/rss-refresh.js": {
      "maxDuration": 120
    },
    "api/cron/weekly-newsletter.js": {
      "maxDuration": 180
    },
    "api/cron/smart-briefing.js": {
      "maxDuration": 120
    },
    "api/cron/scrape-monitor.js": {
      "maxDuration": 120
    },
    "api/cron/web-scraping-refresh.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/cron/daily-digest", "destination": "/api/cron/daily-digest.js" },
    { "source": "/api/cron/rss-refresh", "destination": "/api/cron/rss-refresh.js" },
    { "source": "/api/cron/bank-news-refresh", "destination": "/api/cron/bank-news-refresh.js" },
    { "source": "/api/cron/fca-enforcement", "destination": "/api/cron/fca-enforcement.js" },
    { "source": "/api/cron/weekly-newsletter", "destination": "/api/cron/weekly-newsletter.js" },
    { "source": "/api/cron/smart-briefing", "destination": "/api/cron/smart-briefing.js" },
    { "source": "/api/cron/scrape-monitor", "destination": "/api/cron/scrape-monitor.js" },
    { "source": "/api/cron/web-scraping-refresh", "destination": "/api/cron/web-scraping-refresh.js" },
    { "source": "/(.*)", "destination": "/api/index.js" }
  ],
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/rss-refresh",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/bank-news-refresh",
      "schedule": "15 9 * * *"
    },
    {
      "path": "/api/cron/fca-enforcement",
      "schedule": "5 9 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/weekly-newsletter",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/cron/smart-briefing",
      "schedule": "30 9 * * 1"
    },
    {
      "path": "/api/cron/web-scraping-refresh",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron/scrape-monitor",
      "schedule": "0 12 * * *"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "START_SERVER": "false",
    "VERCEL": "1"
  }
}
